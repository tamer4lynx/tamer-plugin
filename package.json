{
  "name": "@tamer4lynx/tamer-plugin",
  "version": "0.0.4",
  "publishConfig": {
    "access": "public",
    "tag": "prerelease"
  },
  "type": "module",
  "description": "Optional middleman for Tamer plugins in lynx.config: inject defaults from tamer.config or overrides, or disable by name.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0"
  },
  "scripts": {
    "build": "tsc"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.3.0",
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tamer4lynx/tamer-plugin.git"
  },
  "homepage": "https://github.com/tamer4lynx/tamer-plugin#readme",
  "bugs": {
    "url": "https://github.com/tamer4lynx/tamer-plugin/issues"
  },
  "author": "Nanofuxion",
  "license": "MIT"
}
