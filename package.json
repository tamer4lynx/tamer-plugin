{
  "name": "tamer-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "Optional middleman for Tamer plugins in lynx.config: inject defaults from tamer.config or overrides, or disable by name.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0"
  },
  "scripts": {
    "build": "tsc"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.3.0",
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Nanofuxion",
  "license": "MIT"
}
